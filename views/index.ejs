<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Modern Todo App</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    padding:20px;
    background:linear-gradient(135deg,#667eea 0%,#764ba2 50%,#6b46c1 100%);
}

.container{
    width:100%;
    max-width:700px;
    backdrop-filter:blur(20px);
    background:rgba(255,255,255,0.12);
    border:1px solid rgba(255,255,255,0.2);
    border-radius:30px;
    padding:35px;
    box-shadow:0 8px 32px rgba(0,0,0,0.25);
}

.header{
    text-align:center;
    margin-bottom:25px;
}

.header h1{
    color:#fff;
    font-size:2.2rem;
}

.header p{
    color:rgba(255,255,255,.8);
    margin-top:8px;
}

.stats{
    display:flex;
    gap:10px;
    margin-bottom:25px;
}

.card{
    flex:1;
    background:rgba(255,255,255,0.15);
    padding:15px;
    border-radius:15px;
    text-align:center;
    color:white;
}

.card h3{
    font-size:24px;
}

.todo-form{
    display:flex;
    gap:12px;
    margin-bottom:25px;
}

.todo-form input{
    flex:1;
    padding:14px 18px;
    border:none;
    border-radius:15px;
    outline:none;
}

.todo-form button{
    border:none;
    padding:14px 24px;
    border-radius:15px;
    cursor:pointer;
    background:white;
    color:#6b46c1;
    font-weight:600;
    transition:.3s;
}

.todo-form button:hover{
    transform:translateY(-3px);
}

.todo-list{
    max-height:450px;
    overflow-y:auto;
}

.todo-item{
    background:white;
    border-radius:18px;
    padding:16px;
    margin-bottom:12px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    transition:.3s;
}

.todo-item:hover{
    transform:translateY(-2px);
}

.todo-left{
    display:flex;
    align-items:center;
    gap:12px;
}

.todo-checkbox{
    width:22px;
    height:22px;
    cursor:pointer;
}

.todo-number{
    width:32px;
    height:32px;
    border-radius:50%;
    background:#667eea;
    color:white;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:14px;
    font-weight:600;
}

.todo-text{
    font-weight:500;
    color:#333;
}

.completed{
    text-decoration:line-through;
    color:#888;
    opacity:.7;
}

.status{
    font-size:14px;
    font-weight:600;
}

.pending{
    color:#f59e0b;
}

.done{
    color:#10b981;
}

.empty{
    text-align:center;
    color:white;
    padding:40px;
}

.footer{
    margin-top:20px;
    text-align:center;
    color:rgba(255,255,255,.8);
}

@media(max-width:600px){

    .stats{
        flex-direction:column;
    }

    .todo-form{
        flex-direction:column;
    }

    .todo-item{
        flex-direction:column;
        align-items:flex-start;
        gap:10px;
    }
}

</style>
</head>
<body>

<div class="container">

    <div class="header">
        <h1>🚀 Smart Todo App</h1>
        <p>Stay organized. Stay productive.</p>
    </div>

    <div class="stats">

        <div class="card">
            <h3><%= todos.length %></h3>
            <p>Total Tasks</p>
        </div>

        <div class="card">
            <h3><%= todos.filter(t => t.completed).length %></h3>
            <p>Completed</p>
        </div>

        <div class="card">
            <h3><%= todos.filter(t => !t.completed).length %></h3>
            <p>Pending</p>
        </div>

    </div>

    <form class="todo-form" action="/add" method="POST">
        <input
            type="text"
            name="task"
            placeholder="What needs to be done today?"
            required>

        <button type="submit">
            ➕ Add Task
        </button>
    </form>

    <% if(todos.length === 0){ %>

        <div class="empty">
            <h2>📭 No Tasks Yet</h2>
            <p>Add your first task and start being productive.</p>
        </div>

    <% } %>

    <div class="todo-list">

        <% todos.forEach(function(todo,index){ %>

            <div class="todo-item">

                <div class="todo-left">

                    <form action="/toggle/<%= index %>" method="POST">

                        <input
                            class="todo-checkbox"
                            type="checkbox"
                            onchange="this.form.submit()"
                            <%= todo.completed ? 'checked' : '' %>
                        >

                    </form>

                    <div class="todo-number">
                        <%= index + 1 %>
                    </div>

                    <div class="todo-text <%= todo.completed ? 'completed' : '' %>">
                        <%= todo.text %>
                    </div>

                </div>

                <div class="status <%= todo.completed ? 'done' : 'pending' %>">

                    <%= todo.completed ? '✅ Completed' : '⏳ Pending' %>

                </div>

            </div>

        <% }) %>

    </div>

    <div class="footer">
        Made with ❤️ by Joey & Chandler
    </div>

</div>

</body>
</html>
