<!DOCTYPE html>
<html>
<head>
    <title>Todo App</title>
</head>
<body>

    <h1>My Todo List</h1>

    <form action="/add" method="POST">
        <input
            type="text"
            name="task"
            placeholder="Enter task"
            required>
        <button type="submit">Add Task</button>
    </form>

    <ul>
        <% todos.forEach(function(todo){ %>
            <li><%= todo %></li>
        <% }) %>
    </ul>

</body>
</html>
