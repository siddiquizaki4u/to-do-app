<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Modern Todo App</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    padding:20px;

    background:
    linear-gradient(135deg,#667eea 0%,#764ba2 50%,#6b46c1 100%);
}

.container{
    width:100%;
    max-width:650px;

    backdrop-filter: blur(20px);
    background:rgba(255,255,255,0.12);

    border:1px solid rgba(255,255,255,0.2);

    border-radius:30px;
    padding:35px;

    box-shadow:
    0 8px 32px rgba(0,0,0,0.25);
}

.header{
    text-align:center;
    margin-bottom:25px;
}

.header h1{
    color:#fff;
    font-size:2.3rem;
    font-weight:700;
}

.header p{
    color:rgba(255,255,255,.8);
    margin-top:8px;
}

.stats{
    display:flex;
    justify-content:space-between;
    margin-bottom:25px;
}

.card{
    flex:1;
    margin:0 5px;
    background:rgba(255,255,255,0.15);
    padding:15px;
    border-radius:15px;
    text-align:center;
    color:white;
}

.card h3{
    font-size:22px;
}

.todo-form{
    display:flex;
    gap:12px;
    margin-bottom:25px;
}

.todo-form input{
    flex:1;
    padding:14px 18px;
    border:none;
    border-radius:15px;
    outline:none;
    font-size:15px;
}

.todo-form button{
    border:none;
    padding:14px 24px;
    border-radius:15px;
    cursor:pointer;

    background:#fff;
    color:#6b46c1;

    font-weight:600;

    transition:.3s;
}

.todo-form button:hover{
    transform:translateY(-3px);
}

.todo-list{
    max-height:420px;
    overflow-y:auto;
}

.todo-list::-webkit-scrollbar{
    width:6px;
}

.todo-list::-webkit-scrollbar-thumb{
    background:white;
    border-radius:20px;
}

.todo-item{
    background:white;
    border-radius:18px;
    padding:16px 18px;
    margin-bottom:12px;

    display:flex;
    align-items:center;
    justify-content:space-between;

    animation:slideUp .3s ease;
    transition:.3s;
}

.todo-item:hover{
    transform:translateY(-3px);
}

.todo-left{
    display:flex;
    align-items:center;
    gap:12px;
}

.todo-number{
    width:32px;
    height:32px;
    border-radius:50%;
    background:#667eea;
    color:white;

    display:flex;
    justify-content:center;
    align-items:center;

    font-size:14px;
    font-weight:600;
}

.todo-text{
    color:#333;
    font-weight:500;
}

.status{
    color:#10b981;
    font-size:14px;
    font-weight:600;
}

.empty{
    text-align:center;
    color:white;
    padding:40px 20px;
}

.empty h2{
    margin-bottom:10px;
}

.footer{
    margin-top:25px;
    text-align:center;
    color:rgba(255,255,255,.8);
    font-size:14px;
}

@keyframes slideUp{
    from{
        opacity:0;
        transform:translateY(20px);
    }
    to{
        opacity:1;
        transform:translateY(0);
    }
}

@media(max-width:600px){

    .todo-form{
        flex-direction:column;
    }

    .stats{
        flex-direction:column;
        gap:10px;
    }
}

</style>
</head>
<body>

<div class="container">

    <div class="header">
        <h1>🚀 Smart Todo Bhai ne bola karne ka to matlab karne ka</h1>
        <p>Stay organized. Stay productive.</p>
    </div>

    <div class="stats">
        <div class="card">
            <h3><%= todos.length %></h3>
            <p>Total Tasks</p>
        </div>

        <div class="card">
            <h3>⚡</h3>
            <p>Today's Goals</p>
        </div>
    </div>

    <form class="todo-form" action="/add" method="POST">
        <input
            type="text"
            name="task"
            placeholder="What needs to be done today?"
            required>

        <button type="submit">
            ➕ Add Task
        </button>
    </form>

    <% if(todos.length === 0){ %>

        <div class="empty">
            <h2>📭 No Tasks Yet</h2>
            <p>Add your first task and start being productive.</p>
        </div>

    <% } %>

    <div class="todo-list">

        <% todos.forEach(function(todo,index){ %>

            <div class="todo-item">

                <div class="todo-left">

                    <div class="todo-number">
                        <%= index + 1 %>
                    </div>

                    <div class="todo-text">
                        <%= todo %>
                    </div>

                </div>

                <div class="status">
                    Pending
                </div>

            </div>

        <% }) %>

    </div>

    <div class="footer">
        Made with ❤️ JOEY AND CHANDLER
    </div>

</div>

</body>
</html>
